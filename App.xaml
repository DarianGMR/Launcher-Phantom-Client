<Application x:Class="LauncherPhantom.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0E27"/>
            <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#1A1F3A"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#00D9FF"/>
            <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#7B2CBF"/>
            <SolidColorBrush x:Key="AccentTertiaryBrush" Color="#39FF14"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="#FF3333"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#00FF00"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FFB800"/>

            <!-- Modern Button Style -->
            <Style TargetType="Button" x:Key="ModernButtonStyle">
                <Setter Property="Background" Value="#00D9FF"/>
                <Setter Property="Foreground" Value="#0A0E27"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00B8D4"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0099B8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox Styles -->
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#1A1F3A"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="BorderBrush" Value="#2A3050"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CaretBrush" Value="#00D9FF"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="0">
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#00D9FF"/>
                                    <Setter Property="Background" Value="#1F2540"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#003D5C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- PasswordBox Styles -->
            <Style TargetType="PasswordBox">
                <Setter Property="Background" Value="#1A1F3A"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="BorderBrush" Value="#2A3050"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CaretBrush" Value="#00D9FF"/>
            </Style>

            <!-- CheckBox Styles -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="#A0A0A0"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>