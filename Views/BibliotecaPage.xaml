<Page x:Class="LauncherPhantom.Views.BibliotecaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Biblioteca" Background="#0A0E27" Foreground="#FFFFFF">
    
    <Grid Margin="30">
        <!-- Empty State -->
        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="📚 BIBLIOTECA" FontSize="28" Foreground="#00D9FF" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock x:Name="LibraryStatus" Text="Cargando juegos locales..." Foreground="#A0A0A0" FontSize="14" TextAlignment="Center" Margin="0,0,0,20"/>
        </StackPanel>
        
        <!-- Game Grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GamesList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1A1F3A" Margin="15" Width="200" Height="260">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.4" Color="#00D9FF"/>
                            </Border.Effect>
                            <StackPanel VerticalAlignment="Stretch">
                                <Image Source="{Binding ImageUrl}" Height="150" Stretch="UniformToFill"/>
                                <StackPanel Margin="15,10,15,10" VerticalAlignment="Stretch">
                                    <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontSize="13" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Version}" Foreground="#A0A0A0" FontSize="10" Margin="0,5,0,0"/>
                                    <Button Content="▶ JUGAR" Background="#00D9FF" Foreground="#000000" Margin="0,15,0,0" Height="35" FontWeight="Bold" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>