<Window x:Class="LauncherPhantom.Views.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Descargando Actualización"
        Width="440"
        Height="290"
        WindowStartupLocation="CenterOwner"
        Background="#0A0E27"
        Foreground="#FFFFFF"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Closing="Window_Closing"
        Icon="pack://application:,,,/Resources/Images/icon.ico"
        Topmost="True">
    
    <Border Background="#0A0E27" CornerRadius="12" BorderBrush="#00D9FF" BorderThickness="2">
        <Grid Margin="20,15,20,15">
            <StackPanel VerticalAlignment="Stretch">
                <!-- Título -->
                <TextBlock Text="Descargando Actualización" 
                           FontSize="22" 
                           FontWeight="Bold"
                           Foreground="#00D9FF"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- Contenedor de Barra de Progreso -->
                <Grid Margin="0,0,0,6" Height="45">
                    <!-- Fondo de la barra -->
                    <Border Background="#1A1F3A" 
                            BorderBrush="#00D9FF"
                            CornerRadius="8"
                            BorderThickness="1.5"
                            Height="35"
                            VerticalAlignment="Center"/>
                    
                    <!-- Barra de progreso con animación izquierda a derecha y esquinas redondeadas -->
                    <ProgressBar x:Name="ProgressBar" 
                                 Height="34"
                                 Foreground="#00D9FF"
                                 Background="Transparent"
                                 Margin="0"
                                 Value="0"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 ClipToBounds="True">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <Grid x:Name="PART_Track" ClipToBounds="True">
                                        <Border x:Name="PART_Indicator" 
                                                Background="{TemplateBinding Foreground}"
                                                HorizontalAlignment="Left"
                                                CornerRadius="8"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                    
                    <!-- Porcentaje sobre la barra (Centro) -->
                    <TextBlock x:Name="PercentageText" 
                               Text="0%" 
                               Foreground="#FFFFFF" 
                               FontSize="17"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="1.0"/>
                </Grid>

                <!-- Información de Descarga -->
                <Grid Margin="0,0,0,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Bytes descargados (Fila 0) -->
                    <TextBlock x:Name="BytesText" 
                               Text="Descargado: 0.00 MB / 0.00 MB" 
                               Foreground="#A0A0A0" 
                               FontSize="16"
                               Grid.Row="0"
                               Margin="0,0,0,3"/>
                    
                    <!-- Velocidad de descarga (Fila 1) -->
                    <TextBlock x:Name="SpeedText" 
                               Text="Velocidad: 0.00 KB/s" 
                               Foreground="#A0A0A0" 
                               FontSize="16"
                               Grid.Row="1"
                               Margin="0,0,0,3"/>
                    
                    <!-- Tiempo restante (Fila 2) -->
                    <TextBlock x:Name="TimeRemainingText" 
                               Text="Tiempo restante: 00:00" 
                               Foreground="#A0A0A0" 
                               FontSize="16"
                               Grid.Row="2"
                               Margin="0,0,0,3"/>
                </Grid>

                <!-- Estado -->
                <TextBlock x:Name="StatusText" 
                           Text="Iniciando descarga..." 
                           Foreground="#39FF14" 
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,5"
                           MinHeight="26"/>

                <!-- Botón Cancelar -->
                <Button x:Name="CancelDownloadButton" 
                        Content="Cancelar Descarga" 
                        Background="#FF3333"
                        Foreground="#FFFFFF"
                        Padding="20,10"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CancelDownloadButton_Click"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        Width="190"
                        Height="45"
                        Focusable="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                   Padding="{TemplateBinding Padding}"
                                   CornerRadius="8"
                                   BorderBrush="#FF6666"
                                   BorderThickness="2"
                                   x:Name="border">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                 VerticalAlignment="Center"
                                                 TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#FF6666"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FFAAAA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#5F0000"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FF0000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#664444"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
