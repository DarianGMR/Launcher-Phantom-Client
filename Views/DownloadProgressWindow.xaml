<Window x:Class="LauncherPhantom.Views.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Descargando Actualización"
        Width="600"
        Height="340"
        WindowStartupLocation="CenterOwner"
        Background="#0A0E27"
        Foreground="#FFFFFF"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Closing="Window_Closing"
        Icon="pack://application:,,,/Resources/Images/icon.ico">
    
    <Border Background="#0A0E27" CornerRadius="12" BorderBrush="#00D9FF" BorderThickness="2">
        <Grid Margin="40">
            <StackPanel VerticalAlignment="Stretch">
                <!-- Título -->
                <TextBlock Text="Descargando Actualización" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Foreground="#00D9FF"
                           Margin="0,0,0,25"/>

                <!-- Barra de Progreso -->
                <ProgressBar x:Name="ProgressBar" 
                             Height="28" 
                             Foreground="#00D9FF"
                             Background="#1A1F3A"
                             Margin="0,0,0,15"
                             Value="0"
                             BorderBrush="#00D9FF"
                             BorderThickness="1"/>

                <!-- Porcentaje -->
                <TextBlock x:Name="PercentageText" 
                           Text="0%" 
                           Foreground="#39FF14" 
                           FontSize="16"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- Información de Descarga -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock x:Name="BytesText" 
                              Text="0 MB / 0 MB" 
                              Foreground="#A0A0A0" 
                              FontSize="13"
                              Margin="0,0,0,6"/>
                    
                    <TextBlock x:Name="SpeedText" 
                              Text="Velocidad: 0 MB/s" 
                              Foreground="#A0A0A0" 
                              FontSize="13"
                              Margin="0,0,0,6"/>
                    
                    <TextBlock x:Name="TimeRemainingText" 
                              Text="Tiempo restante: Calculando..." 
                              Foreground="#A0A0A0" 
                              FontSize="13"/>
                </StackPanel>

                <!-- Estado -->
                <TextBlock x:Name="StatusText" 
                           Text="Iniciando descarga..." 
                           Foreground="#00D9FF" 
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,25"/>

                <!-- Botón Cancelar - Centrado -->
                <Button x:Name="CancelDownloadButton" 
                        Content="Cancelar" 
                        Background="#FF3333"
                        Foreground="#FFFFFF"
                        Padding="30,12"
                        FontSize="13"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CancelDownloadButton_Click"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        Width="200">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                   Padding="{TemplateBinding Padding}"
                                   CornerRadius="6"
                                   BorderBrush="#FF6666"
                                   BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF6666"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CC0000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#664444"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
