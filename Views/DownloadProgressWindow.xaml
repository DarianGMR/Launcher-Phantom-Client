<Window x:Class="LauncherPhantom.Views.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Descargando Actualización"
        Width="650"
        Height="380"
        WindowStartupLocation="CenterOwner"
        Background="#0A0E27"
        Foreground="#FFFFFF"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Closing="Window_Closing"
        Icon="pack://application:,,,/Resources/Images/icon.ico"
        Topmost="True">
    
    <Border Background="#0A0E27" CornerRadius="12" BorderBrush="#00D9FF" BorderThickness="2">
        <Grid Margin="40,35,40,35">
            <StackPanel VerticalAlignment="Stretch">
                <!-- Título -->
                <TextBlock Text="Descargando Actualización" 
                           FontSize="22" 
                           FontWeight="Bold"
                           Foreground="#00D9FF"
                           Margin="0,0,0,30"/>

                <!-- Contenedor de Barra de Progreso con Porcentaje Superpuesto -->
                <Grid Margin="0,0,0,20" Height="60">
                    <!-- Fondo de la barra -->
                    <Border Background="#1A1F3A" 
                            CornerRadius="8"
                            BorderBrush="#00D9FF"
                            BorderThickness="1.5"
                            Height="50"
                            VerticalAlignment="Center"/>
                    
                    <!-- Barra de progreso actual -->
                    <ProgressBar x:Name="ProgressBar" 
                                 Height="50"
                                 Foreground="#00D9FF"
                                 Background="Transparent"
                                 Margin="0"
                                 Value="0"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 ClipToBounds="True">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <Grid x:Name="PART_Track" ClipToBounds="True">
                                        <Border x:Name="PART_Indicator" 
                                                Background="{TemplateBinding Foreground}"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                    
                    <!-- Porcentaje SOBRE la barra (Centro) -->
                    <TextBlock x:Name="PercentageText" 
                               Text="0%" 
                               Foreground="#FFFFFF" 
                               FontSize="18"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="1.0"/>
                </Grid>

                <!-- Información de Descarga -->
                <Grid Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Bytes descargados -->
                    <TextBlock x:Name="BytesText" 
                               Text="0.00 MB / 0.00 MB" 
                               Foreground="#A0A0A0" 
                               FontSize="13"
                               Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,10,3"/>
                    
                    <!-- Velocidad -->
                    <TextBlock x:Name="SpeedText" 
                               Text="Velocidad: 0.00 MB/s" 
                               Foreground="#A0A0A0" 
                               FontSize="13"
                               Grid.Row="0"
                               Grid.Column="1"
                               TextAlignment="Right"
                               Margin="10,0,0,3"/>
                    
                    <!-- Tiempo restante -->
                    <TextBlock x:Name="TimeRemainingText" 
                               Text="Tiempo restante: --:--" 
                               Foreground="#A0A0A0" 
                               FontSize="13"
                               Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Margin="0,0,0,3"/>
                    
                    <!-- Información adicional -->
                    <TextBlock x:Name="ProgressInfoText" 
                               Text="" 
                               Foreground="#B0B0B0" 
                               FontSize="11"
                               Grid.Row="2"
                               Grid.ColumnSpan="2"
                               FontStyle="Italic"/>
                </Grid>

                <!-- Estado -->
                <TextBlock x:Name="StatusText" 
                           Text="Iniciando descarga..." 
                           Foreground="#39FF14" 
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"
                           MinHeight="26"/>

                <!-- Botón Cancelar - Con mejor responsividad -->
                <Button x:Name="CancelDownloadButton" 
                        Content="Cancelar Descarga" 
                        Background="#FF3333"
                        Foreground="#FFFFFF"
                        Padding="30,15"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CancelDownloadButton_Click"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        Width="220"
                        Height="50"
                        Focusable="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                   Padding="{TemplateBinding Padding}"
                                   CornerRadius="8"
                                   BorderBrush="#FF6666"
                                   BorderThickness="2"
                                   x:Name="border">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                 VerticalAlignment="Center"
                                                 TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#FF6666"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FFAAAA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#CC0000"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FF0000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#664444"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>