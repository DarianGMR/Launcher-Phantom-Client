<Page x:Class="LauncherPhantom.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A0E27"
      Foreground="#FFFFFF">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Top Bar -->
        <Grid Grid.Row="0" Background="#050A1F" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Content with Padding -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,15,0,15">
                <!-- Welcome Message -->
                <TextBlock x:Name="WelcomeText" 
                          Text="Bienvenido, Usuario" 
                          Foreground="#00D9FF" 
                          FontSize="20"
                          FontWeight="Bold"
                          Margin="0,0,0,5"/>
                <TextBlock x:Name="ConnectionStatus" 
                          Text="✓ Conectado al servidor" 
                          Foreground="#00FF00" 
                          FontSize="12"
                          Margin="0,0,0,0"/>
            </StackPanel>
            
            <!-- Logout Button -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button x:Name="LogoutButton"
                        Content="Cerrar Sesión" 
                        Background="#FF3333"
                        Foreground="#FFFFFF"
                        Padding="15,10"
                        FontSize="13"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="LogoutButton_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Background="#0A0E27">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                <!-- Icon -->
                <Image Source="pack://application:,,,/Resources/Images/icon.ico" 
                       Width="150" 
                       Height="150" 
                       Margin="0,0,0,30"
                       HorizontalAlignment="Center"/>
                
                <!-- Title -->
                <TextBlock Text="DASHBOARD" 
                          Foreground="#00D9FF" 
                          FontSize="32"
                          FontWeight="Bold"
                          TextAlignment="Center"
                          Margin="0,0,0,30"/>
                
                <!-- Info Box -->
                <Border Background="#1A1F3A" 
                       CornerRadius="8" 
                       Padding="20" 
                       Margin="0,0,0,20"
                       BorderBrush="#00D9FF"
                       BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Estado del Sistema" 
                                  Foreground="#00D9FF" 
                                  FontSize="14"
                                  FontWeight="Bold"
                                  Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Servidor: " 
                                      Foreground="#A0A0A0" 
                                      FontSize="12"/>
                            <TextBlock x:Name="ServerStatusText" 
                                      Text="Conectado" 
                                      Foreground="#00FF00" 
                                      FontSize="12"
                                      FontWeight="Bold"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Versión: " 
                                      Foreground="#A0A0A0" 
                                      FontSize="12"/>
                            <TextBlock x:Name="VersionText" 
                                      Text="0.1.0" 
                                      Foreground="#39FF14" 
                                      FontSize="12"
                                      FontWeight="Bold"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Actualización: " 
                                      Foreground="#A0A0A0" 
                                      FontSize="12"/>
                            <TextBlock x:Name="UpdateStatusText" 
                                      Text="Al día" 
                                      Foreground="#00FF00" 
                                      FontSize="12"
                                      FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Message Box -->
                <TextBlock x:Name="DashboardMessage" 
                          Text="Sistema inicializado correctamente" 
                          Foreground="#A0A0A0" 
                          FontSize="13"
                          TextAlignment="Center"
                          TextWrapping="Wrap"
                          Margin="0,0,0,20"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>