<Page x:Class="LauncherPhantom.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" 
      Background="#0A0E27"
      Foreground="#FFFFFF"
      Loaded="DashboardPage_Loaded"
      Unloaded="DashboardPage_Unloaded">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- SIDEBAR IZQUIERDO -->
        <Border Grid.Column="0" Background="#050A1F" BorderThickness="0,0,1,0" BorderBrush="#00D9FF" Opacity="0.95">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                
                <!-- Logo/Title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Image Source="pack://application:,,,/Resources/Images/icon.ico" Width="60" Height="60" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="1"/>
                    <TextBlock Text="PHANTOM" Foreground="#00D9FF" FontSize="16" FontWeight="Bold" TextAlignment="Center" Opacity="1"/>
                </StackPanel>
                
                <!-- Navigation Buttons -->
                <Button x:Name="BibliotecaButton" Click="BibliotecaButton_Click" 
                        Background="Transparent" Foreground="#A0A0A0" BorderThickness="0"
                        Height="50" Margin="10,5,10,5" HorizontalAlignment="Stretch"
                        MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" Padding="10">
                                <TextBlock Text="📚 BIBLIOTECA" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button x:Name="CatalogoButton" Click="CatalogoButton_Click"
                        Background="Transparent" Foreground="#A0A0A0" BorderThickness="0"
                        Height="50" Margin="10,5,10,5" HorizontalAlignment="Stretch"
                        MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" Padding="10">
                                <TextBlock Text="🎮 JUEGOS" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button x:Name="WebButton" Click="WebButton_Click"
                        Background="Transparent" Foreground="#A0A0A0" BorderThickness="0"
                        Height="50" Margin="10,5,10,5" HorizontalAlignment="Stretch"
                        MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" Padding="10">
                                <TextBlock Text="🌐 WEB" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button x:Name="NoticiasButton" Click="NoticiasButton_Click"
                        Background="Transparent" Foreground="#A0A0A0" BorderThickness="0"
                        Height="50" Margin="10,5,10,5" HorizontalAlignment="Stretch"
                        MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" Padding="10">
                                <TextBlock Text="📰 NOTICIAS" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button x:Name="CreditsButton" Click="CreditsButton_Click"
                        Background="Transparent" Foreground="#A0A0A0" BorderThickness="0"
                        Height="50" Margin="10,5,10,5" HorizontalAlignment="Stretch"
                        MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" Padding="10">
                                <TextBlock Text="⭐ CRÉDITOS" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Separator Margin="10,15,10,15" Background="#00D9FF" Opacity="0.3"/>
                
                <Button x:Name="ProfileButton" Click="ProfileButton_Click"
                        Background="Transparent" Foreground="#A0A0A0" BorderThickness="0"
                        Height="50" Margin="10,5,10,5" HorizontalAlignment="Stretch"
                        MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" Padding="10">
                                <TextBlock Text="👤 PERFIL" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
            </StackPanel>
        </Border>
        
        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#050A1F" Height="60" BorderThickness="0,0,0,1" BorderBrush="#00D9FF" Opacity="0.95">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,30,0">
                    <TextBlock x:Name="PageTitle" Text="BIBLIOTECA" Foreground="#00D9FF" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content Area -->
            <Frame x:Name="ContentFrame" Grid.Row="1" NavigationUIVisibility="Hidden" Background="#0A0E27" Opacity="1"/>
        </Grid>
    </Grid>
</Page>
