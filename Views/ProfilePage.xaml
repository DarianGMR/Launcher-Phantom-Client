<Page x:Class="LauncherPhantom.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Perfil" Background="#0A0E27" Foreground="#FFFFFF">
    
    <Grid Margin="30" VerticalAlignment="Top">
        <StackPanel MaxWidth="600">
            <!-- Profile Header -->
            <Border Background="#1A1F3A" Padding="20" Margin="0,0,0,30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.3" Color="#00D9FF"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Ellipse Width="80" Height="80" Fill="#00D9FF" Opacity="0.3" Margin="0,0,20,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="UsernameText" Text="Usuario" Foreground="#00D9FF" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Miembro Premium" Foreground="#A0A0A0" FontSize="12" Margin="0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Stats -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Background="#1A1F3A" Padding="20" Margin="0,0,10,0" Grid.Column="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.25" Color="#00D9FF"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="12" Foreground="#00D9FF" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Juegos" Foreground="#A0A0A0" FontSize="11" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#1A1F3A" Padding="20" Margin="10,0,10,0" Grid.Column="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.25" Color="#00D9FF"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="245h" Foreground="#00D9FF" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Jugadas" Foreground="#A0A0A0" FontSize="11" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#1A1F3A" Padding="20" Margin="10,0,0,0" Grid.Column="2">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.25" Color="#00D9FF"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="95.5GB" Foreground="#00D9FF" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Usados" Foreground="#A0A0A0" FontSize="11" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Actions -->
            <Button Content="🚪 CERRAR SESIÓN" Background="#FF3333" Foreground="#FFFFFF" 
                    Height="45" FontSize="14" FontWeight="Bold" Click="LogoutButton_Click" Cursor="Hand">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.2" Color="#FF3333"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</Page>