<Window x:Class="LauncherPhantom.Views.UpdateCheckSplash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Phantom"
        Width="600"
        Height="400"
        WindowStartupLocation="CenterOwner"
        Background="#0A0E27"
        Foreground="#FFFFFF"
        WindowStyle="None"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Images/icon.ico"
        ShowInTaskbar="False">
    
    <Border BorderBrush="#00D9FF" BorderThickness="2" CornerRadius="10">
        <Grid>
            <!-- Animated Background -->
            <Canvas Background="#0A0E27">
                <Ellipse Width="600" Height="600" Fill="#00D9FF" Opacity="0.04" Canvas.Left="-150" Canvas.Top="-150"/>
                <Ellipse Width="500" Height="500" Fill="#7B2CBF" Opacity="0.05" Canvas.Right="-200" Canvas.Bottom="-200"/>
                <Ellipse Width="400" Height="400" Fill="#39FF14" Opacity="0.03" Canvas.Left="100" Canvas.Bottom="-100"/>
            </Canvas>
            
            <!-- Content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
                <!-- Icon -->
                <Image x:Name="SplashIcon" 
                       Source="pack://application:,,,/Resources/Images/icon.ico" 
                       Width="120" 
                       Height="120" 
                       Margin="0,0,0,30"
                       HorizontalAlignment="Center"/>
                
                <!-- Title -->
                <TextBlock Text="VERIFICANDO ACTUALIZACIONES" 
                          Foreground="#00D9FF" 
                          FontSize="24"
                          FontWeight="Bold"
                          TextAlignment="Center"
                          Margin="0,0,0,30"/>
                
                <!-- Checking State -->
                <Grid x:Name="CheckingGrid" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Spinner -->
                        <ProgressBar x:Name="CheckSpinner" 
                                    Width="200" 
                                    Height="3" 
                                    Foreground="#00D9FF"
                                    Background="#1A1F3A"
                                    IsIndeterminate="True"
                                    Margin="0,0,0,20"/>
                        
                        <!-- Status Text -->
                        <TextBlock x:Name="CheckingText" 
                                  Text="Verificando versiones disponibles..." 
                                  Foreground="#A0A0A0" 
                                  FontSize="13"
                                  TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
                
                <!-- No Update Found (Auto-hide after 3 seconds) -->
                <Grid x:Name="NoUpdateGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Icon -->
                        <TextBlock Text="✓" 
                                  Foreground="#00FF00" 
                                  FontSize="48"
                                  TextAlignment="Center"
                                  Margin="0,0,0,15"/>
                        
                        <!-- Message -->
                        <TextBlock Text="Estás actualizado" 
                                  Foreground="#39FF14" 
                                  FontSize="18"
                                  FontWeight="Bold"
                                  TextAlignment="Center"
                                  Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Tu launcher está en la última versión" 
                                  Foreground="#A0A0A0" 
                                  FontSize="12"
                                  TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
                
                <!-- Update Available -->
                <Grid x:Name="UpdateGrid" Visibility="Collapsed">
                    <StackPanel>
                        <!-- Message -->
                        <TextBlock Text="¡Actualización Disponible!" 
                                  Foreground="#00D9FF" 
                                  FontSize="18"
                                  FontWeight="Bold"
                                  TextAlignment="Center"
                                  Margin="0,0,0,15"/>
                        
                        <!-- Version Info -->
                        <Border Background="#1A1F3A" 
                               CornerRadius="6" 
                               Padding="15" 
                               Margin="0,0,0,15"
                               BorderBrush="#00D9FF"
                               BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="UpdateVersionText" 
                                          Text="Nueva versión disponible" 
                                          Foreground="#39FF14" 
                                          FontSize="13"
                                          FontWeight="Bold"
                                          Margin="0,0,0,8"/>
                                
                                <TextBlock x:Name="UpdateChangesText" 
                                          Text="Cambios incluidos en la actualización" 
                                          Foreground="#A0A0A0" 
                                          FontSize="12"
                                          TextWrapping="Wrap"
                                          MaxHeight="80"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="UpdateButton"
                                   Content="Actualizar Ahora" 
                                   Background="#00D9FF"
                                   Foreground="#0A0E27"
                                   Padding="20,12"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Cursor="Hand"
                                   Margin="0,0,10,0"
                                   Click="UpdateButton_Click"/>
                            
                            <Button x:Name="CancelButton"
                                   Content="Cancelar" 
                                   Background="#FF3333"
                                   Foreground="#FFFFFF"
                                   Padding="20,12"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Cursor="Hand"
                                   Click="CancelButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>