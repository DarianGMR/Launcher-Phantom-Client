<Page x:Class="LauncherPhantom.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A0E27"
      Foreground="#FFFFFF">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel - Branding -->
        <Grid Grid.Column="0" Background="#0A0E27">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Background Elements -->
            <Canvas Grid.Row="0" Grid.RowSpan="3" Background="#0A0E27">
                <Ellipse Width="250" Height="250" Fill="#00D9FF" Opacity="0.06" Canvas.Left="-80" Canvas.Top="-60"/>
                <Ellipse Width="180" Height="180" Fill="#7B2CBF" Opacity="0.08" Canvas.Right="-40" Canvas.Bottom="-40"/>
            </Canvas>
            
            <!-- Content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200">
                <!-- Icon -->
                <TextBlock Text="◆" 
                           Foreground="#00D9FF" 
                           FontSize="56"
                           TextAlignment="Center"
                           Margin="0,0,0,12"
                           FontWeight="Bold"/>
                
                <!-- Title -->
                <TextBlock Text="LAUNCHER" 
                           Foreground="#00D9FF" 
                           FontSize="16"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,0"/>
                
                <TextBlock Text="PHANTOM" 
                           Foreground="#39FF14" 
                           FontSize="16"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,12"/>
                
                <!-- Version -->
                <TextBlock Text="v0.1 - FASE INICIAL" 
                           Foreground="#7B2CBF" 
                           FontSize="8"
                           TextAlignment="Center"
                           Opacity="0.8"/>
            </StackPanel>
        </Grid>
        
        <!-- Right Panel - Login Form -->
        <Grid Grid.Column="1" Background="#0A0E27">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="220" Margin="10">
                <!-- Title -->
                <TextBlock Text="Iniciar Sesión" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Foreground="#00D9FF"
                           Margin="0,0,0,14"
                           TextAlignment="Center"/>

                <!-- Username -->
                <TextBlock Text="Usuario" Foreground="#A0A0A0" FontSize="9" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="UsernameTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="8"
                         Height="32"
                         Margin="0,0,0,10"
                         BorderBrush="#2A3050"
                         BorderThickness="1"
                         FontSize="11"/>

                <!-- Password -->
                <TextBlock Text="Contraseña" Foreground="#A0A0A0" FontSize="9" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordBox" 
                             Background="#1A1F3A" 
                             Foreground="#FFFFFF"
                             Padding="8"
                             Height="32"
                             Margin="0,0,0,10"
                             BorderBrush="#2A3050"
                             BorderThickness="1"
                             FontSize="11"/>

                <!-- Server IP -->
                <TextBlock Text="IP Servidor" Foreground="#A0A0A0" FontSize="9" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="ServerIpTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="8"
                         Height="32"
                         Margin="0,0,0,10"
                         BorderBrush="#2A3050"
                         BorderThickness="1"
                         Text="localhost:5000"
                         FontSize="11"/>

                <!-- Remember Me -->
                <CheckBox x:Name="RememberMeCheckBox" 
                          Content="Recuérdame" 
                          Foreground="#A0A0A0"
                          Margin="0,0,0,10"
                          FontSize="9"/>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessageText" 
                           Foreground="#FF3333" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="Collapsed"
                           FontSize="9"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton" 
                        Content="Iniciar Sesión" 
                        Background="#00D9FF"
                        Foreground="#0A0E27"
                        Padding="8"
                        Height="32"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,0,0,8"
                        FontSize="11"
                        Click="LoginButton_Click"
                        BorderThickness="0"
                        Style="{DynamicResource ModernButtonStyle}"/>

                <!-- Register Link -->
                <TextBlock TextAlignment="Center" Margin="0,0,0,0">
                    <Run Text="¿No tienes cuenta? " Foreground="#A0A0A0" FontSize="8"/>
                    <Hyperlink Foreground="#00D9FF" Click="RegisterLink_Click" FontSize="8" TextDecorations="None">
                        <Run Text="Regístrate"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Page>