<Page x:Class="LauncherPhantom.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A0E27"
      Foreground="#FFFFFF">
    
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Width="400">
            <!-- Logo -->
            <Image Width="100" Height="100" Margin="0,0,0,30" HorizontalAlignment="Center"/>

            <!-- Title -->
            <TextBlock Text="Iniciar Sesión" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="#00D9FF"
                       Margin="0,0,0,30"
                       TextAlignment="Center"
                       FontFamily="pack://application:,,,/Resources/Fonts/#Orbitron"/>

            <!-- Username -->
            <TextBlock Text="Usuario o Email" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox" 
                     Background="#1A1F3A" 
                     Foreground="#FFFFFF"
                     Padding="10"
                     Height="40"
                     Margin="0,0,0,15"/>

            <!-- Password -->
            <TextBlock Text="Contraseña" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="10"
                         Height="40"
                         Margin="0,0,0,15"/>

            <!-- Server IP -->
            <TextBlock Text="Dirección IP del Servidor" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="ServerIpTextBox" 
                     Background="#1A1F3A" 
                     Foreground="#FFFFFF"
                     Padding="10"
                     Height="40"
                     Margin="0,0,0,15"
                     Text="localhost:5000"/>

            <!-- Remember Me -->
            <CheckBox x:Name="RememberMeCheckBox" 
                      Content="Recuérdame" 
                      Foreground="#FFFFFF"
                      Margin="0,0,0,20"/>

            <!-- Error Message -->
            <TextBlock x:Name="ErrorMessageText" 
                       Foreground="#FF3333" 
                       TextWrapping="Wrap"
                       Margin="0,0,0,15"
                       Visibility="Collapsed"/>

            <!-- Login Button -->
            <Button x:Name="LoginButton" 
                    Content="Iniciar Sesión" 
                    Background="#00D9FF"
                    Foreground="#0A0E27"
                    Padding="10"
                    Height="40"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Margin="0,0,0,15"
                    Click="LoginButton_Click"/>

            <!-- Register Link -->
            <TextBlock TextAlignment="Center" Margin="0,15,0,0">
                <Run Text="¿No tienes cuenta? " Foreground="#A0A0A0"/>
                <Hyperlink Foreground="#00D9FF" Click="RegisterLink_Click">Regístrate aquí</Hyperlink>
            </TextBlock>

            <!-- Forgot Password (Disabled) -->
            <TextBlock TextAlignment="Center" Margin="0,10,0,0">
                <Hyperlink Foreground="#666666" IsEnabled="False">¿Olvidaste contraseña?</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>