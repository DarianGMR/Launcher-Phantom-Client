<Page x:Class="LauncherPhantom.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A0E27"
      Foreground="#FFFFFF">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel - Branding -->
        <Grid Grid.Column="0" Background="#0A0E27">
            <!-- Background Elements -->
            <Canvas Background="#0A0E27">
                <Ellipse Width="300" Height="300" Fill="#00D9FF" Opacity="0.05" Canvas.Left="-80" Canvas.Top="-80"/>
                <Ellipse Width="250" Height="250" Fill="#7B2CBF" Opacity="0.06" Canvas.Right="-100" Canvas.Bottom="-100"/>
                <Ellipse Width="200" Height="200" Fill="#39FF14" Opacity="0.03" Canvas.Left="0" Canvas.Bottom="0"/>
            </Canvas>
            
            <!-- Content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Icon -->
                <Image Source="pack://application:,,,/Resources/Images/icon.ico" Width="140" Height="140" Margin="0,0,0,25" HorizontalAlignment="Center"/>
                
                <!-- Title -->
                <TextBlock Text="LAUNCHER" 
                           Foreground="#00D9FF" 
                           FontSize="24"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,0"/>
                
                <TextBlock Text="PHANTOM" 
                           Foreground="#39FF14" 
                           FontSize="24"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>
                
                <!-- Version -->
                <TextBlock Text="v0.1 - FASE INICIAL" 
                           Foreground="#7B2CBF" 
                           FontSize="11"
                           TextAlignment="Center"
                           Opacity="0.8"/>
            </StackPanel>
        </Grid>
        
        <!-- Right Panel - Login Form -->
        <Grid Grid.Column="1" Background="#0A0E27">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="260" Margin="20">
                <!-- Title -->
                <TextBlock Text="Iniciar Sesión" 
                           FontSize="18" 
                           FontWeight="Bold"
                           Foreground="#00D9FF"
                           Margin="0,0,0,25"
                           TextAlignment="Center"/>

                <!-- Username -->
                <TextBlock Text="Usuario o Email" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="UsernameTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="12"
                         Height="40"
                         Margin="0,0,0,14"
                         BorderBrush="#2A3050"
                         BorderThickness="1"
                         FontSize="12"
                         Tag="Ingresa tu usuario"/>

                <!-- Password -->
                <TextBlock Text="Contraseña" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordBox" 
                             Background="#1A1F3A" 
                             Foreground="#FFFFFF"
                             Padding="12"
                             Height="40"
                             Margin="0,0,0,14"
                             BorderBrush="#2A3050"
                             BorderThickness="1"
                             FontSize="12"
                             Tag="Ingresa tu contraseña"/>

                <!-- Server IP -->
                <TextBlock Text="IP del Servidor" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="ServerIpTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="12"
                         Height="40"
                         Margin="0,0,0,14"
                         BorderBrush="#2A3050"
                         BorderThickness="1"
                         FontSize="12"
                         Tag="ej: localhost:5000"/>

                <!-- Remember Me -->
                <CheckBox x:Name="RememberMeCheckBox" 
                          Content="Recuérdame" 
                          Foreground="#A0A0A0"
                          Margin="0,0,0,14"
                          FontSize="11"/>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessageText" 
                           Foreground="#FF3333" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"
                           FontSize="10"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton" 
                        Content="Iniciar Sesión" 
                        Background="#00D9FF"
                        Foreground="#0A0E27"
                        Padding="12"
                        Height="40"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,0,0,12"
                        FontSize="12"
                        Click="LoginButton_Click"
                        BorderThickness="0"
                        Style="{DynamicResource ModernButtonStyle}"/>

                <!-- Separator -->
                <Grid Margin="0,0,0,12" Height="1">
                    <Rectangle Fill="#2A3050" Opacity="0.5"/>
                    <TextBlock Text="o" Foreground="#A0A0A0" HorizontalAlignment="Center" Background="#0A0E27" Padding="8,0" FontSize="10"/>
                </Grid>

                <!-- Register Link -->
                <TextBlock TextAlignment="Center" Margin="0,0,0,0">
                    <Run Text="¿No tienes cuenta? " Foreground="#A0A0A0" FontSize="10"/>
                    <Hyperlink Foreground="#00D9FF" Click="RegisterLink_Click" FontSize="10" TextDecorations="None">
                        <Run Text="Regístrate"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Page>