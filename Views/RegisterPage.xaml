<Page x:Class="LauncherPhantom.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A0E27"
      Foreground="#FFFFFF">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel - Branding -->
        <Grid Grid.Column="0" Background="#0A0E27">
            <!-- Background Elements -->
            <Canvas Background="#0A0E27">
                <Ellipse Width="300" Height="300" Fill="#00D9FF" Opacity="0.05" Canvas.Left="-80" Canvas.Top="-80"/>
                <Ellipse Width="250" Height="250" Fill="#7B2CBF" Opacity="0.06" Canvas.Right="-100" Canvas.Bottom="-100"/>
                <Ellipse Width="200" Height="200" Fill="#39FF14" Opacity="0.03" Canvas.Left="0" Canvas.Bottom="0"/>
            </Canvas>
            
            <!-- Content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Icon -->
                <Image Source="pack://application:,,,/Resources/Images/icon.ico" Width="140" Height="140" Margin="0,0,0,25" HorizontalAlignment="Center"/>
                
                <!-- Title -->
                <TextBlock Text="LAUNCHER" 
                           Foreground="#00D9FF" 
                           FontSize="24"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,0"/>
                
                <TextBlock Text="PHANTOM" 
                           Foreground="#39FF14" 
                           FontSize="24"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>
                
                <!-- Benefits -->
                <TextBlock Text="✓ Acceso Rápido" 
                           Foreground="#39FF14" 
                           FontSize="11"
                           TextAlignment="Center"
                           Margin="0,0,0,4"
                           Opacity="0.8"/>
                <TextBlock Text="✓ Panel Premium" 
                           Foreground="#39FF14" 
                           FontSize="11"
                           TextAlignment="Center"
                           Margin="0,0,0,4"
                           Opacity="0.8"/>
                <TextBlock Text="✓ Comunidad" 
                           Foreground="#39FF14" 
                           FontSize="11"
                           TextAlignment="Center"
                           Opacity="0.8"/>
            </StackPanel>
        </Grid>
        
        <!-- Right Panel - Register Form -->
        <Grid Grid.Column="1" Background="#0A0E27">
            <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Center" Width="260" Margin="20,15,20,15">
                <!-- Title -->
                <TextBlock Text="Crear Cuenta" 
                           FontSize="18" 
                           FontWeight="Bold"
                           Foreground="#39FF14"
                           Margin="0,0,0,12"
                           TextAlignment="Center"/>

                <!-- Username -->
                <TextBlock Text="Nombre de Usuario" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="UsernameTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="10"
                         Height="35"
                         Margin="0,0,0,8"
                         BorderBrush="#2A3050"
                         BorderThickness="1"
                         FontSize="11"
                         Tag="Ingresa un nombre"
                         TextChanged="UsernameTextBox_TextChanged"
                         GotFocus="UsernameTextBox_GotFocus"
                         LostFocus="UsernameTextBox_LostFocus"/>

                <!-- Email -->
                <TextBlock Text="Correo Electronico" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="EmailTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="10"
                         Height="35"
                         Margin="0,0,0,8"
                         BorderBrush="#2A3050"
                         BorderThickness="1"
                         FontSize="11"
                         Tag="tu.gmail@gmail.com"
                         TextChanged="EmailTextBox_TextChanged"
                         GotFocus="EmailTextBox_GotFocus"
                         LostFocus="EmailTextBox_LostFocus"/>

                <!-- Server IP -->
                <TextBlock Text="Dirección IP" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="ServerIpTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="10"
                         Height="35"
                         Margin="0,0,0,8"
                         BorderBrush="#2A3050"
                         BorderThickness="1"
                         FontSize="11"
                         Tag="Dirección IP del servidor"
                         TextChanged="ServerIpTextBox_TextChanged"
                         GotFocus="ServerIpTextBox_GotFocus"
                         LostFocus="ServerIpTextBox_LostFocus"/>

                <!-- Password -->
                <TextBlock Text="Contraseña" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordBox" 
                             Background="#1A1F3A" 
                             Foreground="#FFFFFF"
                             Padding="10"
                             Height="35"
                             Margin="0,0,0,4"
                             BorderBrush="#2A3050"
                             BorderThickness="1"
                             FontSize="11"
                             Tag="Ingresa una contraseña"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             GotFocus="PasswordBox_GotFocus"
                             LostFocus="PasswordBox_LostFocus"/>

                <!-- Password Strength -->
                <ProgressBar x:Name="PasswordStrengthBar" 
                             Height="2" 
                             Background="#1A1F3A"
                             Foreground="#FF3333"
                             Margin="0,0,0,1"/>
                <TextBlock x:Name="PasswordStrengthText" 
                           Foreground="#A0A0A0" 
                           FontSize="13" 
                           Margin="0,0,0,1"/>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessageText" 
                           Foreground="#FF3333" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"
                           Visibility="Collapsed"
                           FontSize="13"/>

                <!-- Terms -->
                <CheckBox x:Name="TermsCheckBox" 
                          Foreground="#A0A0A0"
                          Margin="0,0,0,8"
                          FontSize="12">
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="Aceptar "/>
                        <Hyperlink Foreground="#39FF14" Click="TermsLink_Click" TextDecorations="None">
                            <Run Text="Términos y condiciones"/>
                        </Hyperlink>
                    </TextBlock>
                </CheckBox>

                <!-- Register Button -->
                <Button x:Name="RegisterButton" 
                        Content="Registrarse" 
                        Background="#39FF14"
                        Foreground="#0A0E27"
                        Padding="10"
                        Height="36"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,0,0,8"
                        FontSize="12"
                        Click="RegisterButton_Click"
                        BorderThickness="0"
                        Style="{DynamicResource ModernButtonStyle}"/>

                <!-- Separator -->
                <Grid Margin="0,0,0,8" Height="1">
                    <Rectangle Fill="#2A3050" Opacity="0.5"/>
                    <TextBlock Text="o" Foreground="#A0A0A0" HorizontalAlignment="Center" Background="#0A0E27" Padding="6,0" FontSize="9"/>
                </Grid>

                <!-- Login Link -->
                <TextBlock TextAlignment="Center" Margin="0,0,0,0">
                    <Run Text="¿Ya tienes cuenta? " Foreground="#A0A0A0" FontSize="14"/>
                    <Hyperlink Foreground="#00D9FF" Click="LoginLink_Click" FontSize="14" TextDecorations="None">
                        <Run Text="Inicia sesión"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Page>