<Page x:Class="LauncherPhantom.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A0E27"
      Foreground="#FFFFFF">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Width="400" Margin="20">
                <!-- Title -->
                <TextBlock Text="Crear Cuenta" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="#00D9FF"
                           Margin="0,0,0,30"
                           TextAlignment="Center"
                           FontFamily="pack://application:,,,/Resources/Fonts/#Orbitron"/>

                <!-- Username -->
                <TextBlock Text="Usuario" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="10"
                         Height="40"
                         Margin="0,0,0,15"/>

                <!-- Email -->
                <TextBlock Text="Email" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="10"
                         Height="40"
                         Margin="0,0,0,15"/>

                <!-- Server IP -->
                <TextBlock Text="Dirección IP del Servidor" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="ServerIpTextBox" 
                         Background="#1A1F3A" 
                         Foreground="#FFFFFF"
                         Padding="10"
                         Height="40"
                         Margin="0,0,0,15"
                         Text="localhost:5000"/>

                <!-- Password -->
                <TextBlock Text="Contraseña" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" 
                             Background="#1A1F3A" 
                             Foreground="#FFFFFF"
                             Padding="10"
                             Height="40"
                             Margin="0,0,0,15"/>

                <!-- Password Strength Indicator -->
                <ProgressBar x:Name="PasswordStrengthBar" 
                             Height="4" 
                             Background="#1A1F3A"
                             Foreground="#FF3333"
                             Margin="0,0,0,10"/>
                <TextBlock x:Name="PasswordStrengthText" 
                           Foreground="#A0A0A0" 
                           FontSize="10" 
                           Margin="0,0,0,15"/>

                <!-- Confirm Password -->
                <TextBlock Text="Verificar Contraseña" Foreground="#A0A0A0" FontSize="12" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" 
                             Background="#1A1F3A" 
                             Foreground="#FFFFFF"
                             Padding="10"
                             Height="40"
                             Margin="0,0,0,15"/>

                <!-- Terms -->
                <CheckBox x:Name="TermsCheckBox" 
                          Content="Aceptar Términos y Condiciones" 
                          Foreground="#FFFFFF"
                          Margin="0,0,0,10"/>
                <TextBlock TextAlignment="Center" Margin="0,0,0,20">
                    <Hyperlink Foreground="#00D9FF" NavigateUri="https://example.com/terms">
                        Leer Términos y Condiciones
                    </Hyperlink>
                </TextBlock>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessageText" 
                           Foreground="#FF3333" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"
                           Visibility="Collapsed"/>

                <!-- Register Button -->
                <Button x:Name="RegisterButton" 
                        Content="Registrarse" 
                        Background="#39FF14"
                        Foreground="#0A0E27"
                        Padding="10"
                        Height="40"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,0,0,15"
                        Click="RegisterButton_Click"/>

                <!-- Login Link -->
                <TextBlock TextAlignment="Center" Margin="0,15,0,0">
                    <Run Text="¿Ya tienes cuenta? " Foreground="#A0A0A0"/>
                    <Hyperlink Foreground="#00D9FF" Click="LoginLink_Click">Inicia sesión</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>