<Window x:Class="LauncherPhantom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Phantom" 
        MinWidth="640"
        MinHeight="480"
        Width="1280" 
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E27"
        Foreground="#FFFFFF"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Icon="pack://application:,,,/Resources/Images/icon.ico">
    
    <Grid>
        <!-- Main Frame for navigation (base layer) -->
        <Frame x:Name="MainFrame" 
               NavigationUIVisibility="Hidden"
               Background="#0A0E27"
               Visibility="Collapsed"/>
        
        <!-- Loading Overlay (middle layer) -->
        <Grid x:Name="LoadingOverlay" 
              Background="#0A0E27" 
              Opacity="1"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <!-- Animated Logo -->
                <TextBlock Text="◆" 
                           Foreground="#00D9FF" 
                           FontSize="48"
                           TextAlignment="Center"
                           Margin="0,0,0,20"
                           x:Name="AnimatedLogo"
                           FontWeight="Bold"/>
                
                <!-- Title -->
                <TextBlock Text="LAUNCHER PHANTOM" 
                           Foreground="#00D9FF" 
                           FontSize="24"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,30"
                           Opacity="0.9"/>
                
                <!-- Animated Loading Bars -->
                <Grid Margin="0,0,0,20" Height="60">
                    <Canvas>
                        <ProgressBar x:Name="LoadBar1" Width="30" Height="3" Foreground="#00D9FF" Canvas.Left="10" Canvas.Top="10"/>
                        <ProgressBar x:Name="LoadBar2" Width="30" Height="3" Foreground="#7B2CBF" Canvas.Left="50" Canvas.Top="10"/>
                        <ProgressBar x:Name="LoadBar3" Width="30" Height="3" Foreground="#39FF14" Canvas.Left="90" Canvas.Top="10"/>
                        <ProgressBar x:Name="LoadBar4" Width="30" Height="3" Foreground="#00D9FF" Canvas.Left="130" Canvas.Top="10"/>
                        <ProgressBar x:Name="LoadBar5" Width="30" Height="3" Foreground="#FFB800" Canvas.Left="170" Canvas.Top="10"/>
                    </Canvas>
                </Grid>
                
                <!-- Loading Text -->
                <TextBlock x:Name="LoadingText" 
                           Text="Cargando recursos..." 
                           Foreground="#A0A0A0" 
                           FontSize="12"
                           TextAlignment="Center"
                           Margin="0,0,0,10"/>
                
                <!-- Percentage -->
                <TextBlock x:Name="LoadingPercentage" 
                           Text="0%" 
                           Foreground="#00D9FF" 
                           FontSize="14"
                           FontWeight="Bold"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Splash Screen (top layer) -->
        <Grid x:Name="SplashScreen" Background="#0A0E27">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Animated Background Left -->
            <Canvas Grid.Column="0" Background="#0A0E27">
                <Ellipse Width="400" Height="400" Fill="#00D9FF" Opacity="0.05" Canvas.Left="-100" Canvas.Top="-100"/>
                <Ellipse Width="300" Height="300" Fill="#7B2CBF" Opacity="0.08" Canvas.Right="-50" Canvas.Bottom="-50"/>
                
                <StackPanel Canvas.Left="30" Canvas.Top="50" Width="220">
                    <TextBlock Text="◆◆◆" 
                               Foreground="#00D9FF" 
                               FontSize="64"
                               TextAlignment="Center"
                               Margin="0,0,0,40"
                               FontWeight="Bold"
                               Opacity="0.9"/>
                    
                    <TextBlock Text="LAUNCHER" 
                               Foreground="#00D9FF" 
                               FontSize="32"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,5"/>
                    
                    <TextBlock Text="PHANTOM" 
                               Foreground="#39FF14" 
                               FontSize="32"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,30"/>
                    
                    <TextBlock Text="Cliente Launcher Phantom v0.1" 
                               Foreground="#A0A0A0" 
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>
                    
                    <Line X1="0" Y1="0" X2="200" Y2="0" Stroke="#00D9FF" StrokeThickness="1" Margin="10,0"/>
                </StackPanel>
            </Canvas>
            
            <!-- Progress and Info Right -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
                <ProgressBar x:Name="SplashProgressBar" 
                             Width="280" 
                             Height="8" 
                             Foreground="#00D9FF"
                             Background="#1A1F3A"
                             Margin="0,0,0,20"
                             Value="0"/>
                
                <TextBlock Text="Inicializando..." 
                           Foreground="#A0A0A0" 
                           FontSize="13"
                           TextAlignment="Center"
                           Margin="0,0,0,10"
                           x:Name="SplashStatus"/>
                
                <ProgressBar x:Name="SplashDotsProgress" 
                             Width="100" 
                             Height="4" 
                             Foreground="#7B2CBF"
                             Background="#1A1F3A"
                             Margin="0,0,0,20"
                             HorizontalAlignment="Center"
                             IsIndeterminate="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>