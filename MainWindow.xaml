<Window x:Class="LauncherPhantom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Phantom" 
        Width="640" 
        Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E27"
        Foreground="#FFFFFF"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Icon="pack://application:,,,/Resources/Images/icon.ico">
    
    <Grid>
        <!-- Title Bar with Custom Buttons -->
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#050A1F" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Title and Icon -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Source="pack://application:,,,/Resources/Images/icon.ico" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="LAUNCHER PHANTOM" Foreground="#00D9FF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Opacity="0.95"/>
            </StackPanel>
            
            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch" HorizontalAlignment="Right">
                <!-- Minimize Button -->
                <Button x:Name="MinimizeButton" 
                        Width="35" 
                        Height="35" 
                        Background="Transparent" 
                        Foreground="#00D9FF"
                        BorderThickness="0"
                        FontSize="14"
                        Cursor="Hand"
                        Click="MinimizeButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A2050"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0F1535"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="−" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                </Button>
                
                <!-- Close Button -->
                <Button x:Name="CloseButton" 
                        Width="35" 
                        Height="35" 
                        Background="Transparent" 
                        Foreground="#FF3333"
                        BorderThickness="0"
                        FontSize="16"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3D1515"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#2A0F0F"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="✕" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>
            
            <!-- Separator Line -->
            <Rectangle Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="1" Fill="#00D9FF" Opacity="0.2"/>
        </Grid>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <!-- Main Frame for navigation (base layer) -->
            <Frame x:Name="MainFrame" 
                   NavigationUIVisibility="Hidden"
                   Background="#0A0E27"
                   Visibility="Collapsed"/>
            
            <!-- Loading Overlay (middle layer) -->
            <Grid x:Name="LoadingOverlay" 
                  Background="#0A0E27" 
                  Opacity="1"
                  Visibility="Collapsed">
                
                <!-- Animated Background -->
                <Canvas Background="#0A0E27">
                    <Ellipse Width="600" Height="600" Fill="#00D9FF" Opacity="0.04" Canvas.Left="-150" Canvas.Top="-150"/>
                    <Ellipse Width="500" Height="500" Fill="#7B2CBF" Opacity="0.05" Canvas.Right="-200" Canvas.Bottom="-200"/>
                </Canvas>
                
                <!-- Content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
                    <!-- Icon/Image -->
                    <Image x:Name="LoadingIconImage" Source="pack://application:,,,/Resources/Images/icon.ico" Width="120" Height="120" Margin="0,0,0,30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    
                    <!-- Title -->
                    <TextBlock Text="LAUNCHER PHANTOM" 
                               Foreground="#00D9FF" 
                               FontSize="24"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,40"
                               Opacity="0.95"/>
                    
                    <!-- Rotating Loader Animation -->
                    <Grid Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,30">
                        <Canvas>
                            <!-- Outer Circle -->
                            <Ellipse Canvas.Left="20" Canvas.Top="20" Width="60" Height="60" Stroke="#00D9FF" StrokeThickness="2" Fill="Transparent" Opacity="0.3"/>
                            <!-- Rotating Element -->
                            <Ellipse x:Name="LoadingSpinner" Canvas.Left="48" Canvas.Top="10" Width="4" Height="4" Fill="#00D9FF" OpacityMask="#00D9FF"/>
                        </Canvas>
                    </Grid>
                    
                    <!-- Status Text -->
                    <TextBlock x:Name="LoadingText" 
                               Text="Cargando recursos..." 
                               Foreground="#A0A0A0" 
                               FontSize="12"
                               TextAlignment="Center"
                               Margin="0,0,0,8"/>
                    
                    <!-- Loading Text Animation -->
                    <TextBlock x:Name="LoadingPercentage" 
                               Text="0%" 
                               Foreground="#00D9FF" 
                               FontSize="16"
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Splash Screen (top layer) -->
            <Grid x:Name="SplashScreen" Background="#0A0E27">
                <!-- Animated Background -->
                <Canvas Background="#0A0E27">
                    <Ellipse Width="600" Height="600" Fill="#00D9FF" Opacity="0.04" Canvas.Left="-150" Canvas.Top="-150"/>
                    <Ellipse Width="500" Height="500" Fill="#7B2CBF" Opacity="0.05" Canvas.Right="-200" Canvas.Bottom="-200"/>
                    <Ellipse Width="400" Height="400" Fill="#39FF14" Opacity="0.03" Canvas.Left="100" Canvas.Bottom="-100"/>
                </Canvas>
                
                <!-- Content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
                    <!-- Logo -->
                    <Image x:Name="SplashIconImage" Source="pack://application:,,,/Resources/Images/icon.ico" Width="140" Height="140" Margin="0,0,0,35" HorizontalAlignment="Center"/>
                    
                    <!-- Title -->
                    <TextBlock Text="LAUNCHER" 
                               Foreground="#00D9FF" 
                               FontSize="28"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,3"/>
                    
                    <TextBlock Text="PHANTOM" 
                               Foreground="#39FF14" 
                               FontSize="28"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,30"/>
                    
                    <!-- Progress Bar -->
                    <ProgressBar x:Name="SplashProgressBar" 
                                 Width="300" 
                                 Height="6" 
                                 Foreground="#00D9FF"
                                 Background="#1A1F3A"
                                 Margin="0,0,0,20"
                                 Value="0"/>
                    
                    <!-- Status Text -->
                    <TextBlock Text="Inicializando..." 
                               Foreground="#A0A0A0" 
                               FontSize="12"
                               TextAlignment="Center"
                               x:Name="SplashStatus"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>